{
  "schemaVersion": "1.0",
  "framework": "node",
  "language": "typescript",
  "architecture": {
    "style": "feature-modules",
    "moduleRoot": "src/features",
    "docsRoot": "docs"
  },
  "database": {
    "engine": "none",
    "status": "not-configured"
  },
  "rules": [
    {
      "id": "PB001",
      "severity": "medium",
      "title": "Documentation drift in architecture docs"
    },
    {
      "id": "PB002",
      "severity": "low",
      "title": "Missing changelog entry for users feature"
    },
    {
      "id": "PB003",
      "severity": "medium",
      "title": "Checklist drift: apply step is missing"
    },
    {
      "id": "PB004",
      "severity": "medium",
      "title": "Structural inconsistency in workout type naming"
    },
    {
      "id": "PB005",
      "severity": "low",
      "title": "Missing expected notes artifact marker"
    }
  ],
  "generatedAt": "deterministic-demo",
  "repository": {
    "root": ".",
    "moduleRoot": "src/features",
    "docsRoot": "docs"
  },
  "modules": [
    {
      "id": "users",
      "name": "users",
      "kind": "feature-module",
      "path": "src/features/users",
      "files": [
        "user-service.ts"
      ]
    },
    {
      "id": "workouts",
      "name": "workouts",
      "kind": "feature-module",
      "path": "src/features/workouts",
      "files": [
        "workout-service.ts",
        "workout-types.ts"
      ]
    }
  ],
  "docs": [
    "ARCHITECTURE.md",
    "ARCHITECTURE_DIAGRAMS.md",
    "CHANGELOG.md",
    "CONSUMER_INTEGRATION_CONTRACT.md",
    "PLAYBOOK_BUSINESS_STRATEGY.md",
    "PLAYBOOK_CHECKLIST.md",
    "PLAYBOOK_NOTES.md",
    "PLAYBOOK_PRODUCT_ROADMAP.md",
    "index.md"
  ]
}
