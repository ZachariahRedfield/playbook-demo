{
  "name": "playbook-demo",
  "version": "1.0.0",
  "description": "Self-hosted Playbook demo repository with guided imperfections",
  "type": "module",
  "bin": {
    "playbook": "./dist/cli.js"
  },
  "files": [
    "dist/**",
    "README.md",
    "docs/**",
    ".playbook/**"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "npm run build",
    "plan": "node dist/cli.js plan",
    "apply": "node dist/cli.js apply",
    "verify": "node dist/cli.js verify",
    "test": "node --test",
    "demo:refresh": "node scripts/demo-refresh.mjs",
    "demo:verify": "node dist/cli.js verify --json",
    "validate:roadmap": "node scripts/validate-roadmap.mjs",
    "validate:delivery": "node scripts/validate-delivery.mjs",
    "ci:determinism": "npm run build && npm test && npm run validate:roadmap && npm run validate:delivery && npm run validate:demo-baseline",
    "docs:update": "node scripts/update-managed-docs.mjs",
    "validate:demo-baseline": "node scripts/validate-demo-baseline.mjs"
  }
}
